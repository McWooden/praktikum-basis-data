-- Membuat database baru
CREATE DATABASE db_akademik;

-- Menggunakan database yang baru dibuat
USE db_akademik;

-- Membuat tabel Mahasiswa
CREATE TABLE Mahasiswa (
    id_mahasiswa INT PRIMARY KEY AUTO_INCREMENT,
    nama VARCHAR(100) NOT NULL,
    jurusan VARCHAR(50) NOT NULL
);

-- Membuat tabel Mata Kuliah
CREATE TABLE MataKuliah (
    id_mk INT PRIMARY KEY AUTO_INCREMENT,
    nama_mk VARCHAR(100) NOT NULL
);

-- Membuat tabel Nilai (Relasi antara Mahasiswa dan Mata Kuliah)
CREATE TABLE Nilai (
    id_nilai INT PRIMARY KEY AUTO_INCREMENT,
    id_mahasiswa INT,
    id_mk INT,
    nilai DECIMAL(5,2),
    FOREIGN KEY (id_mahasiswa) REFERENCES Mahasiswa(id_mahasiswa) ON DELETE CASCADE,
    FOREIGN KEY (id_mk) REFERENCES MataKuliah(id_mk) ON DELETE CASCADE
);

