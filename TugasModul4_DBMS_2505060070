-- A. Menghitung jumlah mahasiswa per jurusan
SELECT 
    jurusan, 
    COUNT(id_mahasiswa) AS jumlah_mahasiswa
FROM 
    Mahasiswa
GROUP BY 
    jurusan;

-- B. Menampilkan mahasiswa dengan nilai tertinggi dalam setiap mata kuliah
SELECT 
    mk.nama_mk AS mata_kuliah, 
    m.nama AS nama_mahasiswa, 
    n.nilai
FROM 
    Nilai n
JOIN 
    Mahasiswa m ON n.id_mahasiswa = m.id_mahasiswa
JOIN 
    MataKuliah mk ON n.id_mk = mk.id_mk
WHERE 
    n.nilai = (
        SELECT MAX(nilai) 
        FROM Nilai n2 
        WHERE n2.id_mk = n.id_mk
    );

-- C. Menampilkan jumlah mata kuliah yang diambil setiap mahasiswa
SELECT 
    m.nama AS nama_mahasiswa, 
    COUNT(n.id_mk) AS jumlah_mata_kuliah_diambil
FROM 
    Mahasiswa m
LEFT JOIN 
    Nilai n ON m.id_mahasiswa = n.id_mahasiswa
GROUP BY 
    m.id_mahasiswa, 
    m.nama;
